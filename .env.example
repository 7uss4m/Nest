# Copy to .env and fill in secrets
JWT_KEY=change_me_to_a_long_random_string_min_32_chars
POSTGRES_PASSWORD=nest_dev
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ntfy server (public instance or your self-hosted URL)
NTFY_URL=https://ntfy.sh
# ntfy access token (from ntfy web UI → Account → Access tokens)
NTFY_TOKEN=your_token_here

# Email (optional — leave blank to disable email notifications)
EMAIL_SMTP_HOST=smtp.example.com
EMAIL_SMTP_PORT=587
EMAIL_USE_SSL=false
EMAIL_USERNAME=your_smtp_username
EMAIL_PASSWORD=your_smtp_password
EMAIL_FROM=nest@yourdomain.com
EMAIL_FROM_NAME=Nest
