# Copy to .env and fill in secrets
JWT_KEY=change_me_to_a_long_random_string_min_32_chars
POSTGRES_PASSWORD=nest_dev
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# Host ports (change if these conflict with other services on your machine)
POSTGRES_PORT=25432
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
API_PORT=5000
WEB_PORT=3000

# Swagger / API docs — set SWAGGER_ENABLED=true to expose /swagger
# Access: GET /swagger?key=YOUR_KEY  or  header X-Swagger-Key: YOUR_KEY
SWAGGER_ENABLED=false
SWAGGER_API_KEY=change_me_to_a_secret_key

# ntfy server (public instance or your self-hosted URL)
NTFY_URL=https://ntfy.sh
# ntfy access token (from ntfy web UI → Account → Access tokens)
NTFY_TOKEN=your_token_here

# Email (optional — leave blank to disable email notifications)
EMAIL_SMTP_HOST=smtp.example.com
EMAIL_SMTP_PORT=587
EMAIL_USE_SSL=false
EMAIL_USERNAME=your_smtp_username
EMAIL_PASSWORD=your_smtp_password
EMAIL_FROM=nest@yourdomain.com
EMAIL_FROM_NAME=Nest
